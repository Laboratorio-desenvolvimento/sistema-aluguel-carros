@startuml DiagramaDeClasses_AluguelCarros

skinparam classAttributeIconSize 0
skinparam classFontSize 12
skinparam packageFontSize 12
skinparam shadowing false
skinparam roundcorner 8
skinparam classBackgroundColor #F8F8F8
skinparam classBorderColor #AAAAAA
skinparam packageBackgroundColor #FAFAFA
skinparam packageBorderColor #777777

' ╔══════════════════════════════════════════════════════╗
' ║   Subsistema 1 – Gestão de Pedidos e Contratos       ║
' ╚══════════════════════════════════════════════════════╝
package "Sistema para gestão de Pedidos e Contratos" {

  ' ┌─────────────────────────────────────────┐
  ' │  acesso                                 │
  ' └─────────────────────────────────────────┘
  
  package "facade" {

    class PedidoFacade {
        + criarPedido(Cliente c, Veiculo v, Date inicio, Date fim) : HTTPResponse
        + cancelarPedido(Pedido p) : HTTPResponse
        + reprovarPedido(Pedido p) : HTTPResponse
        + getPedidos(Usuario u) : Pedido[]
        + executarPedido(Pedido p) : HTTPStatus
    }
     
  }
  
  package "controller" {
    
    class ClienteController {
        + getCliente(Long id) : Cliente
        + criarCliente() : Cliente
        + atualizarCliente(Cliente c) : Cliente
        + removerCliente() : HTTPStatus
    }
    
    class AgenteController {
        + getAgente(Long id) : Agente
        + criarAgente() : Agente
        + atualizarAgente(Agente a) : Agente
        + removerAgente() : HTTPStatus
    }
    
    class VeiculoController {
        + getVeiculos(Agente a) : Veiculo[]
        + getVeiculos() : Veiculo[]
        + getVeiculo(Long id) : Veiculo
        + criarVeiculo(Veiculo v) : HTTPStatus
        + atualizarVeiculo(Veiculo novoVeiculo) : Veiculo
        + removerVeiculo(Veiculo novoVeiculo) : HTTPStatus
        + calcularCusto(Veiculo v, Date inicio, Date fim) : HTTPStatus
    }
    
    class PedidoController {
        + getPedidos(Cliente c) : Pedido[]
        + getPedidos(Agente a) : Pedido[]
        + getPedido(Long id) : Pedido
        + modificarPedido(Cliente c, Pedido p) : Pedido
        + modificarPedido(Agente a, Pedido p) : Pedido
        + criarPedido(Cliente c, Veiculo v, Date inicio, Date fim) : Pedido
        + cancelarPedido(Pedido p) : Pedido
        + executarPedido(Pedido p) : HTTPStatus
        + reprovarPedido(Pedido p) : HTTPResponse
    }
    
    class ContratoController {
        + getContratos(Cliente c) : Contrato[]
        + getContratos(Agente a) : Contrato[]
        + getContrato(Long id) : Contrato
        + criarContrato(Pedido p) : Contrato
    }
    
  }

package "repository" {

 class ClienteRepository {
    save()
    delete()
    update()
    get()
 }
 
 class AgenteRepository {
    save()
    delete()
    update()
    get()
 }
 
 class VeiculoRepository {
    save()
    delete()
    update()
    get()
 }
 
 class PedidoRepository {
    save()
    delete()
    update()
    get()
 }
 
 class ContratoRepository {
    save()
    delete()
    update()
    get()
 }
 
}

  package "model" {

    abstract class UsuarioSistema {
      - login: String
      - senha: String
      - nome: String
      - endereco: String
    }

    class Cliente {
      - rg: String
      - cpf: String
      - profissao: String
    }

    abstract class Agente {
      - cnpj: String
    }

    class Banco {
    }

    class Empresa {
    }

    class EntidadeEmpregadora {
      - nome: String
      - cnpj: String
      - rendimento: Double
    }
    
    class Contrato {
      - id: Long
      - dataInicio: Date
      - dataFim: Date
      - valorTotal: Double
      - tipoPropriedade: TipoPropriedade
      - contratoCredito: ContratoCredito
      - veiculo: Veiculo
    }
    
    class Pedido {
      - id: Long
      - dataSolicitacao: Date
      - status: StatusPedido
      - contrato: Contrato
    }
    
    class ContratoCredito {
    }

    enum StatusPedido {
      INTRODUZIDO
      EM_ANALISE
      APROVADO
      REJEITADO
      CANCELADO
    }

    enum TipoPropriedade {
      CLIENTE
      EMPRESA
      BANCO
    }
    
    class Veiculo {
      - matricula: String
      - ano: Integer
      - marca: String
      - modelo: String
      - placa: String
    }

    Pedido --> StatusPedido
    Pedido "1" --> "1" Veiculo : refere-se a >

    Contrato --> TipoPropriedade

    ' O contrato pertence ao agente que aprovou e executou
    Agente        "1"    --> "0..*" Contrato       : executa/possui >

    ' Pedido aprovado gera contrato
    Pedido "1"    --> "0..1" Contrato       : gera >

    ' Contrato pode estar associado a crédito concedido por banco
    Contrato      "1"    --> "0..1" ContratoCredito : banco pode associar credito >

    ' Automóvel registrado como propriedade no contrato
    Contrato      "0..1" --> "1"    Veiculo       : registra propriedade >
    

    UsuarioSistema <|-- Cliente
    UsuarioSistema <|-- Agente
    Agente         <|-- Banco
    Agente         <|-- Empresa

    Cliente             "1"   *--  "1..3" EntidadeEmpregadora
    
    Banco "1" --> "0..*" ContratoCredito : concede >
    
  }


  ' ┌─────────────────────────────────────────┐
  ' │  controles                              │
  ' └─────────────────────────────────────────┘
  package "services" {
  
    class ClienteService {
        + getCliente(Long id) : Cliente
        + criarCliente() : Cliente
        + atualizarCliente(Cliente c) : Cliente
        + removerCliente() : HTTPStatus
    }
    
    class AgenteService {
        + getAgente(Long id) : Agente
        + criarAgente() : Agente
        + atualizarAgente(Agente a) : Agente
        + removerAgente() : HTTPStatus
    }
    
    class VeiculoService {
        + getVeiculos(Agente a) : Veiculo[]
        + getVeiculos() : Veiculo[]
        + getVeiculo(Long id) : Veiculo
        + criarVeiculo(Veiculo v) : HTTPStatus
        + atualizarVeiculo(Veiculo novoVeiculo) : Veiculo
        + removerVeiculo(Veiculo novoVeiculo) : HTTPStatus
        + calcularCusto(Veiculo v, Date inicio, Date fim) : HTTPStatus
    }
    
    class PedidoService {
        + getPedidos(Cliente c) : Pedido[]
        + getPedidos(Agente a) : Pedido[]
        + getPedido(Long id) : Pedido
        + modificarPedido(Cliente c, Pedido p) : Pedido
        + modificarPedido(Agente a, Pedido p) : Pedido
        + criarPedido(Cliente c, Veiculo v, Date inicio, Date fim) : Pedido
        + cancelarPedido(Pedido p) : Pedido
        + executarPedido(Pedido p) : HTTPStatus
        + reprovarPedido(Pedido p) : HTTPResponse
    }
    
    class ContratoService {
        + getContratos(Cliente c) : Contrato[]
        + getContratos(Agente a) : Contrato[]
        + getContrato(Long id) : Contrato
        + criarContrato(Pedido p) : Contrato
    }

    ClienteController --> Pedido  : gerencia >
    AgenteController  --> Pedido  : gerencia >
    
    ClienteController  --> ClienteService
    AgenteController  --> AgenteService
    VeiculoController  --> VeiculoService
    
    PedidoController  --> PedidoFacade
    PedidoFacade  --> PedidoService
    
    ContratoController  --> ContratoService
    
    ClienteService  --> ClienteRepository
    AgenteService  --> AgenteRepository
    VeiculoService  --> VeiculoRepository
    PedidoService  --> PedidoRepository
    ContratoService  --> ContratoRepository

  }
}

' ╔══════════════════════════════════════════════════════╗
' ║   Subsistema 2 – Construção de Páginas Web           ║
' ╚══════════════════════════════════════════════════════╝
package "Sistema para construção de Páginas Web" {

  package "web" {

    class MicronautView {
    }
  }
}

' ── Dependências entre subsistemas ───────────────────────
MicronautView ..> ClienteController : delega >
MicronautView ..> AgenteController  : delega >
MicronautView ..> UsuarioSistema  : autentica >


    

@enduml
